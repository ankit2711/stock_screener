// ============================================================================
// Stage Analysis Screener
// Replicates: Stage, RS, Momentum, Avg $ Volume, EMA Distance,
//             Cheat Entry, Beta, PEAD, Market Cap
// Author: Atlas (OpenClaw) for Ankit
// Version: 1.0
// ============================================================================

//@version=6
indicator("Stage Analysis Screener", "StageAnalysis", overlay=true, max_labels_count=50)

// ============================================================================
// INPUTS
// ============================================================================

// --- Stage Settings ---
grpStage = "Stage Analysis"
i_sensitivity = input.string("Aggressive", "Sensitivity", options=["Conservative", "Normal", "Aggressive"], group=grpStage)
i_maLength   = input.int(30, "Stage MA Length (Weekly Bars)", minval=10, maxval=60, group=grpStage)
i_slopeLookback = input.int(5, "MA Slope Lookback", minval=1, maxval=20, group=grpStage)

// --- EMA Settings ---
grpEMA = "EMA Settings"
i_emaFast   = input.int(10, "Fast EMA Length", minval=3, maxval=30, group=grpEMA)
i_emaMedium = input.int(21, "Medium EMA Length", minval=10, maxval=50, group=grpEMA)
i_emaSlow   = input.int(50, "Slow EMA Length", minval=20, maxval=100, group=grpEMA)

// --- RS Settings ---
grpRS = "Relative Strength"
i_rsAutoDetect = input.bool(true, "Auto-detect Benchmark (US→SPX, India→CNX500)", group=grpRS)
i_rsBenchmarkManual = input.symbol("SPY", "Manual RS Benchmark (if auto off)", group=grpRS)
i_rsMaLength  = input.int(52, "RS MA Length", minval=10, maxval=100, group=grpRS)

// --- Volume Settings ---
grpVol = "Volume"
i_volAvgLen = input.int(50, "Volume Average Length", minval=10, maxval=200, group=grpVol)

// --- Momentum Settings ---
grpMom = "Momentum"
i_momFast  = input.int(10, "Momentum Fast Period", minval=3, maxval=30, group=grpMom)
i_momSlow  = input.int(20, "Momentum Slow Period", minval=10, maxval=50, group=grpMom)

// --- Beta Settings ---
grpBeta = "Beta"
i_betaLength = input.int(52, "Beta Lookback (bars)", minval=20, maxval=100, group=grpBeta)

// --- PEAD Settings ---
grpPEAD = "PEAD"
i_peadThreshold = input.float(10.0, "PEAD Strong Threshold %", minval=1.0, maxval=50.0, group=grpPEAD)
i_peadWindow    = input.int(5, "PEAD Window (bars after earnings)", minval=1, maxval=20, group=grpPEAD)

// --- Table Display ---
grpDisplay = "Display"
i_showTable = input.bool(true, "Show Info Table", group=grpDisplay)
i_tablePos  = input.string("Top Right", "Table Position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group=grpDisplay)

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

// Convert sensitivity to threshold multiplier
// Aggressive = early detection, Conservative = late/confirmed
sensitivityMult() =>
    i_sensitivity == "Aggressive" ? 0.5 : i_sensitivity == "Normal" ? 1.0 : 1.5

// ============================================================================
// CORE CALCULATIONS
// ============================================================================

// --- 1. Stage Moving Average (30-week SMA equivalent) ---
stageMA = ta.sma(close, i_maLength)

// MA slope: rate of change over lookback period
maSlope = (stageMA - stageMA[i_slopeLookback]) / stageMA[i_slopeLookback] * 100
slopeSens = sensitivityMult()

// Classify MA direction with sensitivity
maRising   = maSlope > (0.5 * slopeSens)
maFalling  = maSlope < -(0.5 * slopeSens)
maFlat     = not maRising and not maFalling

// --- 2. EMAs ---
emaFast   = ta.ema(close, i_emaFast)
emaMedium = ta.ema(close, i_emaMedium)
emaSlow   = ta.ema(close, i_emaSlow)

emaDistFast   = (close - emaFast) / emaFast * 100
emaDistMedium = (close - emaMedium) / emaMedium * 100
emaDistSlow   = (close - emaSlow) / emaSlow * 100

// --- 3. Relative Strength vs Benchmark ---
// Auto-detect: NSE/BSE stocks use CNX500, everything else uses SPX
isIndianStock = str.contains(syminfo.prefix, "NSE") or str.contains(syminfo.prefix, "BSE")
rsBenchmark = i_rsAutoDetect ? (isIndianStock ? "NSE:CNX500" : "SP:SPX") : i_rsBenchmarkManual
benchClose = request.security(rsBenchmark, timeframe.period, close)
rsRaw = close / benchClose
rsMa  = ta.sma(rsRaw, i_rsMaLength)
rsVsBenchmark = (rsRaw - rsMa) / rsMa * 100

rsIsStrong = rsRaw > rsMa
rsIsWeak   = rsRaw < rsMa
rsRising   = rsRaw > rsRaw[1] and rsRaw[1] > rsRaw[2]
rsFalling  = rsRaw < rsRaw[1] and rsRaw[1] < rsRaw[2]

// --- 4. Momentum (Rate of Change acceleration) ---
rocFast = ta.roc(close, i_momFast)
rocSlow = ta.roc(close, i_momSlow)
momAccel = rocFast - rocFast[3]  // acceleration of fast momentum

// Classify momentum
momStrongUp   = rocFast > 0 and momAccel > 0   // ↑↑ rising at accelerating pace
momWeakUp     = rocFast > 0 and momAccel <= 0   // ↑  rising at decelerating pace
momWeakDown   = rocFast < 0 and momAccel >= 0   // ↓  falling at decelerating pace
momStrongDown = rocFast < 0 and momAccel < 0    // ↓↓ falling at accelerating pace

momStr = momStrongUp ? "Strong ↑↑" : momWeakUp ? "Rising ↑" : momWeakDown ? "Weak ↓" : "Weak ↓↓"
momColor = momStrongUp ? color.green : momWeakUp ? color.lime : momWeakDown ? color.orange : color.red

momDesc = momStrongUp ? "Price rising at accelerating pace" :
          momWeakUp ? "Price rising but momentum fading" :
          momWeakDown ? "Price falling but decelerating" :
          "Price falling at accelerating pace"

// --- 5. Average Dollar Volume ---
dollarVol    = close * volume
avgDollarVol = ta.sma(dollarVol, i_volAvgLen)
prevAvgDolVol = ta.sma(dollarVol[10], i_volAvgLen)
volTrend     = avgDollarVol > prevAvgDolVol

// Format dollar volume
volInB = avgDollarVol / 1e9
volInM = avgDollarVol / 1e6

volStr = volInB >= 1 ? str.tostring(volInB, "#.##") + "B" : str.tostring(volInM, "#.##") + "M"
volTrendStr = volTrend ? "Expanding ↑" : "Declining ↓"
volDesc = volTrend ? "Volume expanding - growing interest" : "Volume contracting - weakening interest"

// --- 6. Beta Calculation ---
stockReturns = math.log(close / close[1])
benchReturns = math.log(benchClose / benchClose[1])

stockStdev = ta.stdev(stockReturns, i_betaLength)
benchStdev = ta.stdev(benchReturns, i_betaLength)
correlation = ta.correlation(stockReturns, benchReturns, i_betaLength)
beta = nz(correlation * stockStdev / benchStdev, 1.0)

betaStr = str.tostring(beta, "#.##")
betaColor = beta < 0.8 ? color.green : beta > 1.5 ? color.red : color.white
betaDesc = beta < 0.5 ? "Very Low - Much less volatile than SPX" :
           beta < 0.8 ? "Low - Less volatile than SPX" :
           beta < 1.2 ? "Normal - Similar to SPX" :
           beta < 1.5 ? "High - More volatile than SPX" :
           "Very High - Much more volatile than SPX"

// --- 7. PEAD (Post-Earnings Announcement Drift) ---
// Use earnings data from TradingView
earningsActual = request.earnings(syminfo.tickerid, earnings.actual, barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)

// Track price change since last earnings
var float lastEarningsClose = na
var int   barsSinceEarnings = 0
var float peadPct = 0.0

if not na(earningsActual) and earningsActual != earningsActual[1]
    lastEarningsClose := close[1]  // close before earnings
    barsSinceEarnings := 0

barsSinceEarnings += 1

if not na(lastEarningsClose) and lastEarningsClose > 0
    peadPct := (close - lastEarningsClose) / lastEarningsClose * 100

peadStr = math.abs(peadPct) > i_peadThreshold ? "Strong" :
          math.abs(peadPct) > i_peadThreshold / 2 ? "Moderate" : "Weak"
peadColor = peadPct > i_peadThreshold ? color.green : peadPct < -i_peadThreshold ? color.red : color.white
peadDesc = peadPct > i_peadThreshold ? "Strong post-earnings drift (>" + str.tostring(i_peadThreshold, "#") + "%)" : peadPct < -i_peadThreshold ? "Negative post-earnings drift" : "Minimal post-earnings drift"

// --- 8. Market Cap ---
// TradingView has no direct market cap field — official method is shares × price
sharesOutFQ = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FQ", ignore_invalid_symbol=true)
sharesOutFY = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FY", ignore_invalid_symbol=true)
sharesOut = not na(sharesOutFQ) ? sharesOutFQ : sharesOutFY
mktCapRaw = nz(sharesOut, 0) * close
currSymbol = isIndianStock ? "₹" : "$"

// Format: Trillions / Billions / Millions / Crores / Lakh Crores for Indian stocks
mktCapStr = isIndianStock ?
     (mktCapRaw / 1e7 >= 1e5 ? currSymbol + str.tostring(mktCapRaw / 1e12, "#.##") + " Lakh Cr" :
      mktCapRaw / 1e7 >= 1 ? currSymbol + str.tostring(mktCapRaw / 1e7, "#.##") + " Cr" :
      currSymbol + str.tostring(mktCapRaw, "#.##")) :
     (mktCapRaw >= 1e12 ? currSymbol + str.tostring(mktCapRaw / 1e12, "#.##") + "T" :
      mktCapRaw >= 1e9 ? currSymbol + str.tostring(mktCapRaw / 1e9, "#.##") + "B" :
      mktCapRaw >= 1e6 ? currSymbol + str.tostring(mktCapRaw / 1e6, "#.##") + "M" :
      currSymbol + str.tostring(mktCapRaw, "#.##"))

// --- 8b. Volume Conviction (Delivery proxy) ---
// Delivery data not available in Pine — using volume ratio as conviction proxy
volRatio = volume / ta.sma(volume, i_volAvgLen)
volConviction = volRatio > 2.0 ? "Very High" : volRatio > 1.3 ? "High" : volRatio > 0.7 ? "Normal" : "Low"
volConvColor = volRatio > 2.0 ? color.green : volRatio > 1.3 ? color.lime : volRatio > 0.7 ? color.white : color.red

// ============================================================================
// STAGE DETERMINATION — Meticulous Transition Logic
// ============================================================================

// Persistent stage tracking
var int currentStage = 0  // 0=undefined, 1=S1, 2=S2, 3=S3, 4=S4
var int prevStage = 0
var int stageDuration = 0
var bool stageTransition = false

// --- Core conditions for each stage ---
// Price position
priceAboveMA = close > stageMA
priceBelowMA = close < stageMA

// EMA stack (bullish: fast > medium > slow; bearish: reverse)
bullishEMAStack = emaFast > emaMedium and emaMedium > emaSlow
bearishEMAStack = emaFast < emaMedium and emaMedium < emaSlow

// Volume on breakout (above average)
volExpansion = volume > ta.sma(volume, i_volAvgLen) * 1.5

// Higher highs / lower lows (trend confirmation)
hh = ta.highest(high, 10) > ta.highest(high, 10)[10]
ll = ta.lowest(low, 10) < ta.lowest(low, 10)[10]

// Sensitivity-adjusted thresholds
slopeThresh = 0.3 * slopeSens  // for flat detection

// --- Stage Scoring System ---
// Each stage gets a score; highest score wins.
// This avoids rigid if-else and allows smooth transitions.

float s1Score = 0.0
float s2Score = 0.0
float s3Score = 0.0
float s4Score = 0.0

// ---- Stage 1 (Accumulation/Basing) ----
// MA flattening after decline, price consolidating around MA
s1Score += maFlat ? 3.0 : 0.0
s1Score += (math.abs(emaDistSlow) < 5) ? 2.0 : 0.0  // price near slow EMA
s1Score += (not hh and not ll) ? 1.0 : 0.0  // no clear trend
s1Score += (currentStage == 4 and maSlope > maSlope[3]) ? 2.0 : 0.0  // coming from S4, slope improving
s1Score += rsRising ? 1.0 : 0.0  // early RS improvement

// ---- Stage 2 (Advancing/Mark-Up) ----
// Price above rising MA, bullish EMA stack, strong RS, volume
s2Score += (priceAboveMA and maRising) ? 4.0 : 0.0
s2Score += bullishEMAStack ? 2.0 : 0.0
s2Score += rsIsStrong ? 2.0 : 0.0
s2Score += hh ? 1.0 : 0.0
s2Score += (rocFast > 0) ? 1.0 : 0.0
s2Score += (currentStage == 1 and volExpansion and priceAboveMA) ? 2.0 : 0.0  // breakout from S1

// ---- Stage 3 (Distribution/Topping) ----
// MA flattening after advance, price oscillating around MA, RS weakening
s3Score += (maFlat and currentStage >= 2) ? 3.0 : 0.0
s3Score += (priceAboveMA and not maRising) ? 1.0 : 0.0
s3Score += rsIsWeak ? 2.0 : 0.0
s3Score += (rocFast < 0 and rocSlow > 0) ? 1.5 : 0.0  // momentum divergence
s3Score += (not bullishEMAStack and not bearishEMAStack) ? 1.0 : 0.0  // EMAs tangled
s3Score += (currentStage == 2 and maSlope < maSlope[3]) ? 2.0 : 0.0  // slope deteriorating from S2

// ---- Stage 4 (Declining/Mark-Down) ----
// Price below falling MA, bearish EMA stack, weak RS
s4Score += (priceBelowMA and maFalling) ? 4.0 : 0.0
s4Score += bearishEMAStack ? 2.0 : 0.0
s4Score += rsIsWeak ? 1.0 : 0.0
s4Score += ll ? 1.0 : 0.0
s4Score += (rocFast < 0) ? 1.0 : 0.0
s4Score += (currentStage == 3 and priceBelowMA and volExpansion) ? 2.0 : 0.0  // breakdown from S3

// --- Determine winning stage ---
float maxScore = math.max(math.max(s1Score, s2Score), math.max(s3Score, s4Score))
int newStage = maxScore == s2Score ? 2 : maxScore == s4Score ? 4 : maxScore == s1Score ? 1 : 3

// Handle ties: prefer current stage (stability)
if s1Score == maxScore and currentStage == 1
    newStage := 1
if s2Score == maxScore and currentStage == 2
    newStage := 2
if s3Score == maxScore and currentStage == 3
    newStage := 3
if s4Score == maxScore and currentStage == 4
    newStage := 4

// --- Sensitivity filter: require score margin for transition ---
float marginRequired = i_sensitivity == "Aggressive" ? 0.5 : i_sensitivity == "Normal" ? 1.5 : 3.0

float currentStageScore = currentStage == 1 ? s1Score :
                          currentStage == 2 ? s2Score :
                          currentStage == 3 ? s3Score :
                          currentStage == 4 ? s4Score : 0.0

// Only transition if new stage clearly dominates
if currentStage == 0
    // First bar — just assign
    currentStage := newStage
    stageDuration := 1
    stageTransition := true
else if newStage != currentStage and (maxScore - currentStageScore) >= marginRequired
    prevStage := currentStage
    currentStage := newStage
    stageDuration := 1
    stageTransition := true
else
    stageDuration += 1
    stageTransition := false

// --- Stage strings ---
stageLabel = currentStage == 1 ? "S1" : currentStage == 2 ? "S2" : currentStage == 3 ? "S3" : "S4"
stageFull = currentStage == 1 ? "S1 (Accumulation)" : currentStage == 2 ? "S2 (Advancing)" : currentStage == 3 ? "S3 (Distribution)" : "S4 (Declining)"

transStr = stageTransition and prevStage != 0 ?
           (prevStage == 1 ? "S1" : prevStage == 2 ? "S2" : prevStage == 3 ? "S3" : "S4") +
           " → " + stageLabel + " (New)" : stageLabel

stageColor = currentStage == 1 ? color.blue :
             currentStage == 2 ? color.green :
             currentStage == 3 ? color.yellow :
             color.red

// ============================================================================
// CHEAT ENTRY DETECTION (VCP-style pullback in S2)
// ============================================================================

// Cheat entry conditions:
// 1. Must be in Stage 2
// 2. Price pulled back to near medium EMA (within 2%)
// 3. Volume contracting (dry-up)
// 4. Volatility contracting (ATR declining)
// 5. Still above slow EMA

atr14 = ta.atr(14) 
atrContracting = atr14 < ta.sma(atr14, 20)  // ATR below its average
volDryUp = volume < ta.sma(volume, i_volAvgLen) * 0.7  // volume below 70% of average

cheatPullback = math.abs(emaDistMedium) < 2.5  // price within 2.5% of medium EMA
cheatAboveSlow = close > emaSlow

isCheatEntry = currentStage == 2 and cheatPullback and volDryUp and atrContracting and cheatAboveSlow

cheatStr = isCheatEntry ? "Yes ✓" : "No"
cheatColor = isCheatEntry ? color.green : color.white
cheatDesc = isCheatEntry ? "Pullback Zone - VCP setup" : "Not in Pullback Zone"

// ============================================================================
// RS Details
// ============================================================================

rsStatus = rsIsStrong and rsRising ? "Strong ↑" :
           rsIsStrong and not rsRising ? "Moderate ↑" :
           rsIsWeak and rsFalling ? "Weak ↓" :
           rsIsWeak and not rsFalling ? "Fading ↓" : "Neutral"

rsColor = rsIsStrong ? color.green : rsIsWeak ? color.red : color.white

rsBenchLabel = isIndianStock ? "CNX500" : "SPX"
rsDesc = str.tostring(rsVsBenchmark, "+#.##") + "% vs RS MA, " +
         (rsIsStrong ? "Outperforming " : "Underperforming ") + rsBenchLabel

// ============================================================================
// EMA Distance Details
// ============================================================================

emaStr = "F: " + str.tostring(emaDistFast, "+#.#") + "% | " +
         "M: " + str.tostring(emaDistMedium, "+#.#") + "% | " +
         "S: " + str.tostring(emaDistSlow, "+#.#") + "%"

emaDesc = emaDistSlow > 10 ? "Extended above Slow EMA" :
          emaDistSlow > 0 ? "Healthy cushion above Slow EMA" :
          emaDistSlow > -5 ? "Near Slow EMA" :
          "Below Slow EMA - caution"

emaColor = emaDistSlow > 0 ? color.green : emaDistSlow > -5 ? color.yellow : color.red

// ============================================================================
// VISUAL OVERLAY — EMAs + Stage MA
// ============================================================================

plot(stageMA, "Stage MA (30w)", color=color.new(color.blue, 30), linewidth=2)
plot(emaFast, "Fast EMA", color=color.new(color.red, 40), linewidth=1)
plot(emaMedium, "Medium EMA", color=color.new(color.yellow, 40), linewidth=1)
plot(emaSlow, "Slow EMA", color=color.new(color.aqua, 40), linewidth=2)

// Background color for stage
//bgcolor(color.new(stageColor, 92), title="Stage Background")

// Cheat entry marker
plotshape(isCheatEntry, "Cheat Entry", shape.diamond, location.belowbar, color.lime, size=size.small)

// Stage transition marker
plotshape(stageTransition and barstate.isconfirmed, "Stage Change", shape.triangleup, location.abovebar, stageColor, size=size.small)

// ============================================================================
// INFO TABLE
// ============================================================================

tablePos = i_tablePos == "Top Left" ? position.top_left :
           i_tablePos == "Top Right" ? position.top_right :
           i_tablePos == "Bottom Left" ? position.bottom_left :
           position.bottom_right

if barstate.islast and i_showTable
    var table infoTable = table.new(tablePos, 3, 11, bgcolor=color.new(color.black, 10),
                                     border_width=1, border_color=color.gray)

    // Header
    table.cell(infoTable, 0, 0, "Metric", bgcolor=color.new(color.gray, 50),
               text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "Status", bgcolor=color.new(color.gray, 50),
               text_color=color.white, text_size=size.small)
    table.cell(infoTable, 2, 0, "Details", bgcolor=color.new(color.gray, 50),
               text_color=color.white, text_size=size.small)

    // Row 1: Stage
    table.cell(infoTable, 0, 1, "Stage", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, transStr, text_color=stageColor, text_size=size.small)
    table.cell(infoTable, 2, 1, "Duration: " + str.tostring(stageDuration) +
               " periods | Sens: " + i_sensitivity, text_color=color.white, text_size=size.small)

    // Row 2: Market Cap
    table.cell(infoTable, 0, 2, "Market Cap", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, mktCapRaw > 0 ? mktCapStr : "N/A", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 2, 2, mktCapRaw > 0 ? "Shares outstanding × price" : "No shares data available for this ticker",
               text_color=mktCapRaw > 0 ? color.white : color.orange, text_size=size.small)

    // Row 3: RS
    table.cell(infoTable, 0, 3, "RS (vs " + rsBenchLabel + ")", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, rsStatus, text_color=rsColor, text_size=size.small)
    table.cell(infoTable, 2, 3, rsDesc, text_color=rsColor, text_size=size.small)

    // Row 4: Momentum
    table.cell(infoTable, 0, 4, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, momStr, text_color=momColor, text_size=size.small)
    table.cell(infoTable, 2, 4, momDesc, text_color=momColor, text_size=size.small)

    // Row 5: Avg $ Volume
    table.cell(infoTable, 0, 5, "Average $ Volume", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 5, volStr + " " + volTrendStr, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 2, 5, volDesc, text_color=color.white, text_size=size.small)

    // Row 6: EMA Distance
    table.cell(infoTable, 0, 6, "EMA Distance", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 6, emaStr, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 2, 6, emaDesc, text_color=emaColor, text_size=size.small)

    // Row 7: Cheat Entry
    table.cell(infoTable, 0, 7, "Cheat Entry", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 7, cheatStr, text_color=cheatColor, text_size=size.small)
    table.cell(infoTable, 2, 7, cheatDesc, text_color=cheatColor, text_size=size.small)

    // Row 8: Beta
    table.cell(infoTable, 0, 8, "Beta", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 8, betaStr, text_color=betaColor, text_size=size.small)
    table.cell(infoTable, 2, 8, betaDesc, text_color=betaColor, text_size=size.small)

    // Row 9: Volume Conviction
    table.cell(infoTable, 0, 9, "Vol Conviction", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 9, volConviction + " (" + str.tostring(volRatio, "#.##") + "x)",
               text_color=volConvColor, text_size=size.small)
    table.cell(infoTable, 2, 9, "Current vol vs " + str.tostring(i_volAvgLen) + "-bar avg (delivery proxy)",
               text_color=volConvColor, text_size=size.small)

    // Row 10: PEAD
    table.cell(infoTable, 0, 10, "PEAD", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 10, peadStr + " (" + str.tostring(peadPct, "+#.#") + "%)",
               text_color=peadColor, text_size=size.small)
    table.cell(infoTable, 2, 10, peadDesc, text_color=peadColor, text_size=size.small)

// ============================================================================
// SCREENER OUTPUT (for Pine Screener / Alerts)
// ============================================================================

// These plots can be used in TradingView's screener or alert conditions
plot(currentStage, "Stage Number", display=display.data_window)
plot(s2Score, "S2 Score", display=display.data_window)
plot(rsVsBenchmark, "RS vs MA %", display=display.data_window)
plot(rocFast, "Momentum ROC", display=display.data_window)
plot(beta, "Beta", display=display.data_window)
plot(peadPct, "PEAD %", display=display.data_window)
plot(isCheatEntry ? 1 : 0, "Cheat Entry Signal", display=display.data_window)

// Alert conditions
alertcondition(stageTransition and currentStage == 2, "Entered Stage 2", "Stage 2 Breakout!")
alertcondition(stageTransition and currentStage == 4, "Entered Stage 4", "Stage 4 Breakdown!")
alertcondition(isCheatEntry, "Cheat Entry", "Cheat Entry detected in Stage 2!")